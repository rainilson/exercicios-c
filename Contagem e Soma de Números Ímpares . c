#include <stdio.h>

int main() {

int numero = 1;
int impares = 0;
int soma = 0;

while (numero <= 20){
	
	if( numero % 2 != 0){
		printf("%d\n", numero);
		impares += 1;
		soma += numero;
		
	}
	
	numero += 1;
	
}
printf("quantidade de impares: %d\n", impares);

printf("soma dos impares: %d\n", soma);	
    return 0;
} 
